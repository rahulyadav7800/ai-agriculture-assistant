# ==========================================
# Application
# ==========================================

APP_NAME=AI Agriculture Assistant
APP_VERSION=1.0.0
DEBUG=False

# ==========================================
# Server
# ==========================================

HOST=0.0.0.0
PORT=8000

# ==========================================
# Database
# ==========================================

DATABASE_URL=sqlite:///backend/database/agriculture.db

# ==========================================
# OpenRouter
# ==========================================

OPENROUTER_API_KEY=

OPENROUTER_TEXT_MODEL=openai/gpt-oss-20b:free

OPENROUTER_VISION_MODEL=google/gemma-4-31b-it:free

OPENROUTER_VISION_FALLBACK_MODEL=google/gemma-4-26b-a4b-it:free

OPENROUTER_VISION_SECOND_FALLBACK=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free

# ==========================================
# Gemini
# ==========================================

GEMINI_API_KEY=

GEMINI_VISION_MODEL=models/gemini-3.1-flash-lite

# ==========================================
# PlantNet
# ==========================================

PLANTNET_API_KEY=

# ==========================================
# Weather
# ==========================================

OPENWEATHER_API_KEY=

# ==========================================
# AssemblyAI
# ==========================================

ASSEMBLYAI_API_KEY=

# ==========================================
# Uploads
# ==========================================

UPLOAD_FOLDER=backend/uploads

MAX_IMAGE_SIZE_MB=10

# ==========================================
# AI
# ==========================================

YOLO_MODEL=trained_models/plant_disease.pt

CONFIDENCE_THRESHOLD=0.50

# ==========================================
# Logging
# ==========================================

LOG_LEVEL=INFO

# ==========================================
# Security
# ==========================================

SECRET_KEY=change_this_to_a_long_random_secret_key

JWT_ALGORITHM=HS256

ACCESS_TOKEN_EXPIRE_MINUTES=60